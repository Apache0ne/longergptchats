{
  "manifest_version": 3,
  "name": "LongerGPTChats",
  "version": "1.0.0",
  "description": "Fixes ChatGPT lag on long conversations by virtualizing the message DOM. Only renders a configurable number of messages at a time.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}